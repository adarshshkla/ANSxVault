# ============================================================
#  .env.example — A.N.SXVault Hackathon Fund Tracker
#
#  Copy this file to ".env" and fill in your values.
#  The app runs fully in demo-mode without any of these set.
# ============================================================

# ── IPFS / Pinata ─────────────────────────────────────────────
# Get your JWT from https://app.pinata.cloud  →  API Keys
PINATA_JWT=YOUR_PINATA_JWT_HERE

# ── ANSX Sovereign Identity Mesh Relay ────────────────────────
# Your deployed relay URL (Render / Railway / local)
# Leave blank to use the default: https://ansxvault.onrender.com
ANSX_RELAY_URL=https://ansxvault.onrender.com

# ── Ethereum Provider ─────────────────────────────────────────
# Leave blank to auto-use the in-memory PyEVM testnet (recommended for hackathon demo).
# Or point to Ganache: http://127.0.0.1:8545
# Or a testnet RPC:    https://sepolia.infura.io/v3/YOUR_KEY
ETH_PROVIDER_URL=

# ── iPhone Shortcut NFC Texts ─────────────────────────────────
# These are the EXACT strings each iPhone Shortcut must copy to clipboard.
# Create one Shortcut per role using the iOS Shortcuts app:
#   Action: "Text" → paste value below → "Copy to Clipboard"
#
#  ADMIN   role shortcut text:
#    ANSX-UID:Admin_Tag_001
#
#  AUDITOR role shortcut text:
#    ANSX-UID:Auditor_Tag_002
#
#  PUBLIC  role: no shortcut needed — use the demo launcher button.
